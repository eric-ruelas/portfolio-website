---
import { Download, Copy, Check, Menu, X } from '@lucide/astro';

const resumeUrl = import.meta.env.PUBLIC_RESUME_URL ?? '';
const email = import.meta.env.PUBLIC_EMAIL ?? '';
---

<style>
  /* Compact nav: collapses fast with acceleration */
  #nav-compact-wrapper {
    overflow: hidden;
    transition:
      max-height 0.22s cubic-bezier(0.4, 0, 1, 1),
      opacity 0.18s ease;
  }

  /* Menu wrapper: expands with deceleration (feels like opening a drawer) */
  #mobile-menu {
    overflow: hidden;
    transition:
      max-height 0.38s cubic-bezier(0.0, 0, 0.2, 1),
      opacity 0.28s ease;
  }

  /* Inner content slides down from slightly above */
  #mobile-menu-inner {
    transition: transform 0.38s cubic-bezier(0.0, 0, 0.2, 1);
  }

  /* Staggered button fade-in */
  #mobile-menu .menu-btn {
    transition: opacity 0.22s ease;
  }
</style>

<header class="px-6 pt-6">

  <!-- Compact nav wrapper -->
  <div
    id="nav-compact-wrapper"
    style="max-height: 80px; opacity: 1; pointer-events: auto;"
  >
    <nav class="flex items-center justify-between gap-3 sm:gap-6">
      <a href="/" class="flex items-center gap-3 shrink-0 hover:opacity-75 transition-opacity duration-150">
        <div class="w-10 h-10 rounded-[10px] overflow-hidden shrink-0">
          <img src="/images/profile.jpg" alt="Eric Ruelas" class="w-full h-full object-cover block" />
        </div>
        <div class="flex flex-col leading-tight">
          <span class="text-[#343844] text-[18px] font-normal leading-none">Eric Ruelas</span>
          <span class="text-[#7a7f87] text-[13px] font-normal leading-none mt-1">Senior Product Designer</span>
        </div>
      </a>

      <!-- Desktop CTA buttons -->
      <div class="hidden sm:flex items-center gap-2 shrink-0">
        <button
          id="download-resume-btn"
          data-url={resumeUrl}
          class="group inline-flex items-center gap-2 pl-2 pr-3 py-1.5 rounded-[48px] bg-[#3d4c74] hover:bg-white hover:text-[#3d4c74] border border-transparent hover:border-[#3d4c74] text-[#f9f8f6] text-[14px] cursor-pointer transition-colors duration-200"
        >
          <span class="bg-[#f9f8f6] w-7 h-7 rounded-full flex items-center justify-center shrink-0">
            <span id="download-icon"><Download size={14} color="#3d4c74" strokeWidth={1.5} /></span>
            <span id="download-check-icon" class="hidden"><Check size={14} color="#3d4c74" strokeWidth={1.5} /></span>
          </span>
          <span id="download-label">Download Resume</span>
        </button>

        <button
          id="copy-email-btn"
          data-email={email}
          class="group inline-flex items-center gap-2 pl-3 pr-2 py-1.5 rounded-[48px] border border-[#3d4c74] text-[#3d4c74] hover:bg-[#3d4c74] hover:text-white text-[14px] cursor-pointer transition-colors duration-200"
        >
          <span id="email-label">Copy Email</span>
          <span class="bg-[rgba(61,76,116,0.1)] group-hover:bg-[#f9f8f6] w-7 h-7 rounded-full flex items-center justify-center shrink-0 transition-colors duration-200">
            <span id="email-copy-icon"><Copy size={14} color="#3d4c74" strokeWidth={1.5} /></span>
            <span id="email-check-icon" class="hidden"><Check size={14} color="#3d4c74" strokeWidth={1.5} /></span>
          </span>
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        class="sm:hidden flex items-center justify-center w-9 h-9 rounded-full border border-[#3d4c74] text-[#3d4c74] cursor-pointer"
        aria-label="Open menu"
      >
        <Menu size={16} strokeWidth={1.5} />
      </button>
    </nav>
  </div>

  <!-- Mobile expanded menu -->
  <div
    id="mobile-menu"
    class="sm:hidden flex flex-col"
    style="max-height: 0; opacity: 0; pointer-events: none;"
  >
    <!-- Inner content: slides in from slightly above -->
    <div id="mobile-menu-inner" style="transform: translateY(-10px);">

      <!-- Profile row -->
      <div class="flex items-center gap-4 pt-1">
        <div class="w-16 h-16 rounded-[14px] overflow-hidden shrink-0">
          <img src="/images/profile.jpg" alt="Eric Ruelas" class="w-full h-full object-cover block" />
        </div>
        <div class="flex flex-col leading-tight">
          <span class="text-[#343844] text-[20px] font-normal leading-none">Eric Ruelas</span>
          <span class="text-[#7a7f87] text-[13px] font-normal leading-none mt-1.5">Senior Product Designer</span>
        </div>
        <button
          id="mobile-close-btn"
          class="ml-auto flex items-center justify-center w-9 h-9 rounded-full border border-[#dadce0] text-[#7a7f87] cursor-pointer shrink-0"
          aria-label="Close menu"
        >
          <X size={16} strokeWidth={1.5} />
        </button>
      </div>

      <!-- Buttons with staggered opacity -->
      <div class="flex flex-col items-center gap-3 mt-6 pb-2">
        <button
          id="mobile-download-btn"
          data-url={resumeUrl}
          class="menu-btn inline-flex items-center justify-center gap-2 px-6 py-3 rounded-[48px] bg-[#3d4c74] text-[#f9f8f6] text-[15px] cursor-pointer w-[200px]"
          style="opacity: 0;"
        >
          <span id="mobile-download-icon"><Download size={15} color="#f9f8f6" strokeWidth={1.5} /></span>
          <span id="mobile-download-check" class="hidden"><Check size={15} color="#f9f8f6" strokeWidth={1.5} /></span>
          <span id="mobile-download-label">View Resume</span>
        </button>

        <button
          id="mobile-copy-btn"
          data-email={email}
          class="menu-btn inline-flex items-center justify-center gap-2 px-6 py-3 rounded-[48px] border border-[#3d4c74] text-[#3d4c74] text-[15px] cursor-pointer w-[200px]"
          style="opacity: 0;"
        >
          <span id="mobile-copy-icon"><Copy size={15} color="#3d4c74" strokeWidth={1.5} /></span>
          <span id="mobile-check-icon" class="hidden"><Check size={15} color="#3d4c74" strokeWidth={1.5} /></span>
          <span id="mobile-email-label">Copy Email</span>
        </button>
      </div>

    </div>
  </div>
</header>

<script>
  function triggerDownload(url: string) {
    if (!url) return;
    window.open(url, '_blank', 'noopener,noreferrer');
  }

  function showConfirmation(label: HTMLElement, icon: HTMLElement, check: HTMLElement, defaultText: string) {
    label.textContent = defaultText === 'Download Resume' ? 'Downloaded!' : defaultText === 'View Resume' ? 'Opened!' : 'Copied!';
    icon.classList.add('hidden');
    check.classList.remove('hidden');
    setTimeout(() => {
      label.textContent = defaultText;
      icon.classList.remove('hidden');
      check.classList.add('hidden');
    }, 2000);
  }

  const navWrapper  = document.getElementById('nav-compact-wrapper') as HTMLElement;
  const mobileMenu  = document.getElementById('mobile-menu') as HTMLElement;
  const menuInner   = document.getElementById('mobile-menu-inner') as HTMLElement;
  const downloadBtn2 = document.getElementById('mobile-download-btn') as HTMLElement;
  const copyBtn2     = document.getElementById('mobile-copy-btn') as HTMLElement;

  function openMenu() {
    // Collapse compact nav
    navWrapper.style.maxHeight = '0';
    navWrapper.style.opacity   = '0';
    navWrapper.style.pointerEvents = 'none';

    // Expand menu + slide inner content in
    mobileMenu.style.maxHeight    = '300px';
    mobileMenu.style.opacity      = '1';
    mobileMenu.style.pointerEvents = 'auto';
    menuInner.style.transform     = 'translateY(0)';

    // Stagger buttons
    setTimeout(() => { downloadBtn2.style.opacity = '1'; }, 140);
    setTimeout(() => { copyBtn2.style.opacity     = '1'; }, 200);
  }

  function closeMenu() {
    // Fade buttons out instantly
    downloadBtn2.style.opacity = '0';
    copyBtn2.style.opacity     = '0';

    // Collapse menu
    mobileMenu.style.maxHeight    = '0';
    mobileMenu.style.opacity      = '0';
    mobileMenu.style.pointerEvents = 'none';
    menuInner.style.transform     = 'translateY(-10px)';

    // Restore compact nav
    navWrapper.style.maxHeight    = '80px';
    navWrapper.style.opacity      = '1';
    navWrapper.style.pointerEvents = 'auto';
  }

  document.getElementById('mobile-menu-btn')?.addEventListener('click', openMenu);
  document.getElementById('mobile-close-btn')?.addEventListener('click', closeMenu);

  // Desktop download
  const downloadBtn = document.getElementById('download-resume-btn') as HTMLElement;
  downloadBtn?.addEventListener('click', () => {
    triggerDownload(downloadBtn.dataset.url ?? '');
    showConfirmation(
      document.getElementById('download-label') as HTMLElement,
      document.getElementById('download-icon') as HTMLElement,
      document.getElementById('download-check-icon') as HTMLElement,
      'Download Resume'
    );
  });

  // Desktop copy email
  const emailBtn = document.getElementById('copy-email-btn') as HTMLElement;
  emailBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(emailBtn.dataset.email ?? '');
      showConfirmation(
        document.getElementById('email-label') as HTMLElement,
        document.getElementById('email-copy-icon') as HTMLElement,
        document.getElementById('email-check-icon') as HTMLElement,
        'Copy Email'
      );
    } catch {
      // Clipboard access denied — silently ignore
    }
  });

  // Mobile download
  const mobileDownloadBtn = document.getElementById('mobile-download-btn') as HTMLElement;
  mobileDownloadBtn?.addEventListener('click', () => {
    triggerDownload(mobileDownloadBtn.dataset.url ?? '');
    showConfirmation(
      document.getElementById('mobile-download-label') as HTMLElement,
      document.getElementById('mobile-download-icon') as HTMLElement,
      document.getElementById('mobile-download-check') as HTMLElement,
      'View Resume'
    );
  });

  // Mobile copy email
  const mobileCopyBtn = document.getElementById('mobile-copy-btn') as HTMLElement;
  mobileCopyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(mobileCopyBtn.dataset.email ?? '');
      showConfirmation(
        document.getElementById('mobile-email-label') as HTMLElement,
        document.getElementById('mobile-copy-icon') as HTMLElement,
        document.getElementById('mobile-check-icon') as HTMLElement,
        'Copy Email'
      );
    } catch {
      // Clipboard access denied — silently ignore
    }
  });
</script>
