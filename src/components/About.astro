const email = 'ericruelasdiaz@gmail.com';
---

<section id="about" class="max-w-[800px] mx-auto px-6 py-16 md:py-20">
  <div class="flex flex-col gap-9">
    <p class="text-[22px] text-[#343844] font-normal leading-[1.5]">
      Hi, I'm Eric — a Senior Product Designer based in the San Francisco Bay Area,
      designing complex software that's simple to use.
    </p>

    <div class="text-[15px] text-[#7a7f87] leading-[1.6] flex flex-col gap-4">
      <p>
        I specialize in UX/UI design, product strategy, and Webflow development.
        My focus is on building digital experiences that are intuitive, accessible,
        and centered around real people. Whether it's designing a new feature,
        refreshing a brand, or launching a full site, I help teams move from
        concept to clarity.
      </p>
      <p>
        If you're working on something that makes a difference, I'd love to hear about it.
      </p>
    </div>

  </div>
</section>
