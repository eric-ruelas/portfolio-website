---
import { Mail } from '@lucide/astro';
const email = import.meta.env.PUBLIC_EMAIL ?? '';

const links = [
  { label: 'LinkedIn', handle: 'in/ericruelas', href: 'https://www.linkedin.com/in/ericruelas' },
  { label: 'GitHub', handle: '/eric-ruelas', href: 'https://github.com/eric-ruelas' },
  { label: 'Email', handle: email, href: `mailto:${email}` },
];
---

<footer class="px-6 pt-4 pb-10">
  <div class="bg-[#3d4c74] rounded-2xl px-5 sm:px-8 py-6 sm:py-8">
    <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-6">
      <span class="inline-flex items-center justify-center w-9 h-9 rounded-[6px] bg-white/10">
        <Mail size={18} color="white" strokeWidth={1.5} />
      </span>
      <h2 class="text-[28px] text-white font-normal leading-[1.2]">Contact</h2>
    </div>

    <div class="flex flex-col">
      {links.map((link) => (
        <a
          href={link.href}
          target={link.label !== 'Email' ? '_blank' : undefined}
          rel={link.label !== 'Email' ? 'noopener noreferrer' : undefined}
          class="group flex flex-col sm:flex-row sm:items-baseline py-3 sm:py-4 gap-0.5 sm:gap-0 hover:opacity-70 transition-opacity duration-150"
        >
          <span class="text-[13px] sm:text-[15px] text-white/50 shrink-0">{link.label}</span>
          <span class="hidden sm:block flex-1 mx-4 border-b border-dotted border-white/20"></span>
          <span class="text-[15px] text-white font-medium shrink-0">{link.handle}</span>
        </a>
      ))}
    </div>

    <p class="text-[11px] text-white/30 font-mono mt-8">© 2025 - Eric Ruelas</p>
  </div>
</footer>
