---
const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isNotes = pathname.startsWith('/notes');
---

<style>
  #floating-nav {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    opacity: 0;
    transition:
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.15s ease;
    z-index: 100;
    pointer-events: none;
    will-change: transform, opacity;
  }
  #floating-nav.is-visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }
</style>

<div id="floating-nav" data-always-show={String(!isHome)} aria-label="Site navigation">
  <div class="flex items-center gap-1 bg-white/90 backdrop-blur-md border border-[#dadce0] rounded-full px-2 py-2 shadow-[0_4px_24px_rgba(52,56,68,0.10)]">
    <a
      href="/"
      class:list={[
        'px-4 py-1.5 rounded-full text-[14px] transition-colors duration-150',
        isHome
          ? 'bg-[rgba(61,76,116,0.1)] text-[#3d4c74] font-medium'
          : 'text-[#7a7f87] hover:text-[#343844] hover:bg-[rgba(61,76,116,0.06)]'
      ]}
    >
      Home
    </a>
    <a
      href="/notes"
      class:list={[
        'px-4 py-1.5 rounded-full text-[14px] transition-colors duration-150',
        isNotes
          ? 'bg-[rgba(61,76,116,0.1)] text-[#3d4c74] font-medium'
          : 'text-[#7a7f87] hover:text-[#343844] hover:bg-[rgba(61,76,116,0.06)]'
      ]}
    >
      Notes
    </a>
  </div>
</div>

<script>
  const nav = document.getElementById('floating-nav') as HTMLElement;
  const alwaysShow = nav.dataset.alwaysShow === 'true';

  function update() {
    if (alwaysShow || window.scrollY > 150) {
      nav.classList.add('is-visible');
    } else {
      nav.classList.remove('is-visible');
    }
  }

  window.addEventListener('scroll', update, { passive: true });
  update();
</script>
