---
import { GitCommitHorizontal } from '@lucide/astro';
const username = 'eric-ruelas';
---

<section class="px-6 py-8 sm:py-12">
  <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-3 mb-8">
    <span class="inline-flex items-center justify-center w-9 h-9 rounded-[6px] bg-[rgba(61,76,116,0.1)]">
      <GitCommitHorizontal size={18} color="#3d4c74" strokeWidth={1.5} />
    </span>
    <h2 class="text-[28px] text-[#343844] font-normal leading-[1.2]">Git Activity</h2>
  </div>

  <p class="text-[11px] font-semibold tracking-widest uppercase text-[#7a7f87] mb-3">Last 30 days</p>

  <!-- Grid populated client-side so data is always fresh -->
  <div id="git-grid" class="grid grid-cols-[repeat(30,minmax(0,1fr))] gap-1 w-full">
    {Array.from({ length: 30 }).map(() => (
      <div class="aspect-square w-full rounded-[3px] bg-[#e2e4e9] animate-pulse" />
    ))}
  </div>

  <div class="mt-3 flex items-center justify-between">
    <a
      href={`https://github.com/${username}`}
      target="_blank"
      rel="noopener noreferrer"
      class="text-[13px] text-[#7a7f87] hover:text-[#3d4c74] transition-colors"
    >
      github.com/{username}
    </a>
    <span id="git-total" class="text-[13px] text-[#7a7f87] hidden"></span>
  </div>
</section>

<script>
  const username = 'eric-ruelas';

  const colors: Record<number, string> = {
    0: '#e2e4e9',
    1: 'rgba(61,76,116,0.22)',
    2: 'rgba(61,76,116,0.44)',
    3: 'rgba(61,76,116,0.70)',
    4: '#3d4c74',
  };

  const labels: Record<number, string> = {
    0: 'No activity',
    1: 'Light activity',
    2: 'Moderate activity',
    3: 'Active',
    4: 'Very active',
  };

  async function loadActivity() {
    try {
      const res = await fetch(
        `https://github-contributions-api.jogruber.de/v4/${username}?y=last`,
        { signal: AbortSignal.timeout(6000) }
      );
      const data = await res.json();
      const contributions: { date: string; count: number; level: 0|1|2|3|4 }[] = data.contributions ?? [];
      const recent = contributions.slice(-30);

      const grid = document.getElementById('git-grid');
      if (!grid || recent.length === 0) return;

      grid.innerHTML = recent.map((cell) => `
        <button
          class="aspect-square w-full rounded-[3px] transition-transform duration-150 hover:scale-150 focus-visible:scale-150 focus-visible:outline-none"
          style="background-color: ${colors[cell.level]};"
          title="${cell.date} — ${cell.count} contribution${cell.count !== 1 ? 's' : ''}"
          aria-label="${cell.date}: ${labels[cell.level]}"
        ></button>
      `).join('');

      const total = recent.reduce((sum: number, c: { count: number }) => sum + c.count, 0);
      const totalEl = document.getElementById('git-total');
      if (total > 0 && totalEl) {
        totalEl.textContent = `${total} contributions in the last 30 days`;
        totalEl.classList.remove('hidden');
      }
    } catch {
      // API unavailable — leave skeleton as-is
    }
  }

  loadActivity();
</script>
