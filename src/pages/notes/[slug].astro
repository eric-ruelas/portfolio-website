---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { ArrowLeft } from '@lucide/astro';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content } = await render(note);

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<style is:global>
  .prose h2 {
    font-size: 18px;
    font-weight: 600;
    color: #343844;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }
  .prose p {
    font-size: 15px;
    color: #343844;
    line-height: 1.8;
    margin-bottom: 2rem;
  }
  .prose ul, .prose ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }
  .prose li {
    font-size: 15px;
    color: #343844;
    line-height: 1.8;
    margin-bottom: 0.35rem;
  }
  .prose a {
    color: #3d4c74;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .prose a:hover {
    opacity: 0.7;
  }
  .prose blockquote {
    border-left: 2px solid #dadce0;
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: #7a7f87;
    font-style: italic;
  }
  .prose code {
    font-family: 'Geist Mono', monospace;
    font-size: 13px;
    background: rgba(61, 76, 116, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
  }
  .prose hr {
    border: none;
    border-top: 1px solid #dadce0;
    margin: 2.5rem 0;
  }
</style>

<Layout title={`${note.data.title} — Eric Ruelas`} description={note.data.description}>
  <Navbar />
  <main class="px-6 py-8 sm:py-12">

    <a
      href="/notes"
      class="inline-flex items-center gap-1.5 text-[13px] text-[#7a7f87] hover:text-[#3d4c74] transition-colors duration-150 mb-10"
    >
      <ArrowLeft size={13} strokeWidth={1.5} />
      All notes
    </a>

    <div class="mb-8">
      <p class="text-[13px] text-[#7a7f87] mb-3">{formatDate(note.data.date)}</p>
      <h1 class="text-[28px] text-[#343844] font-normal leading-[1.25] mb-4">{note.data.title}</h1>
      <p class="text-[15px] text-[#7a7f87] leading-[1.6]">{note.data.description}</p>
    </div>

    <hr class="border-[#dadce0] mb-8" />

    <article class="prose">
      <Content />
    </article>

  </main>
</Layout>
